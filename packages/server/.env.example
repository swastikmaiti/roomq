# Copy to .env for local overrides. Every value has a safe default in app/config.py.

# Database (SQLite default; set a Postgres URL to switch).
# DATABASE_URL=sqlite:///./roomq.db

# Public base URLs used to build the links handed out at room creation.
# api_base_url -> agent room_link; ui_base_url -> human viewer link.
# API_BASE_URL=http://localhost:8000
# UI_BASE_URL=http://localhost:3000

# Comma-separated browser origins allowed by CORS (the UI host).
# CORS_ORIGINS=http://localhost:3000

# Room duration bounds (minutes) and caps — see docs/product-plan.md.
# MIN_ROOM_MINUTES=60
# MAX_ROOM_MINUTES=300
# DEFAULT_ROOM_MINUTES=60
# MAX_AGENTS_PER_ROOM=20
# MAX_BATCH_SIZE=10
# MAX_CONTENT_BYTES=32768
# MAX_AGENDA_CHARS=200

# Rate limits.
# LIMIT_IP_ROOMS_PER_DAY=50
# LIMIT_AGENT_MSGS_PER_MIN=60
# LIMIT_ROOM_MSGS_PER_MIN=300
# LIMIT_ROOM_AGENDA_PER_MIN=10
